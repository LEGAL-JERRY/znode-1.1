<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Z-Node — Nigeria's Student Network</title>
    <link href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #000c0a;
            --accent: #10b981;
            --accent-glow: rgba(16,185,129,0.25);
            --text: #f8fafc;
            --muted: #64748b;
            --border: rgba(52,211,153,0.15);
            --ease: cubic-bezier(0.22, 1, 0.36, 1);
        }

        * { margin:0; padding:0; box-sizing:border-box; }

        body {
            background:var(--bg);
            color:var(--text);
            font-family:'Plus Jakarta Sans', sans-serif;
            min-height:100vh;
            overflow-x:hidden;
        }

        /* ── BACKGROUND GRID ── */
        body::before {
            content:'';
            position:fixed; inset:0;
            background-image:
                linear-gradient(rgba(52,211,153,0.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(52,211,153,0.04) 1px, transparent 1px);
            background-size:80px 80px;
            pointer-events:none; z-index:0;
        }

        /* ── NAV ── */
        nav {
            position:fixed; top:0; left:0; right:0; z-index:100;
            display:flex; align-items:center; justify-content:space-between;
            padding:20px 48px;
            background:rgba(0,12,10,0.8);
            backdrop-filter:blur(20px);
            border-bottom:1px solid var(--border);
        }
        .nav-brand {
            font-family:'Clash Display', sans-serif;
            font-size:22px; font-weight:700;
            background:linear-gradient(90deg, #fff, var(--accent));
            -webkit-background-clip:text; -webkit-text-fill-color:transparent;
            letter-spacing:1px;
        }
        .nav-links { display:flex; align-items:center; gap:32px; }
        .nav-links a {
            font-family:'Space Mono', monospace; font-size:12px;
            color:var(--muted); text-decoration:none; text-transform:uppercase; letter-spacing:1px;
            transition:color 0.2s;
        }
        .nav-links a:hover { color:var(--text); }
        .nav-cta {
            padding:10px 24px; border-radius:10px;
            background:var(--accent); color:#000 !important;
            font-weight:700 !important; transition:all 0.2s var(--ease) !important;
        }
        .nav-cta:hover { transform:translateY(-2px); box-shadow:0 8px 24px var(--accent-glow); }

        /* ── HERO ── */
        .hero {
            position:relative; z-index:1;
            min-height:100vh;
            display:flex; flex-direction:column;
            align-items:center; justify-content:center;
            text-align:center;
            padding:120px 24px 80px;
        }

        .hero-eyebrow {
            font-family:'Space Mono', monospace;
            font-size:11px; letter-spacing:3px; text-transform:uppercase;
            color:var(--accent); margin-bottom:24px;
            display:flex; align-items:center; gap:12px;
        }
        .hero-eyebrow::before, .hero-eyebrow::after {
            content:''; display:block; width:40px; height:1px; background:var(--accent); opacity:0.5;
        }

        .hero-title {
            font-family:'Clash Display', sans-serif;
            font-size:clamp(52px, 9vw, 110px);
            font-weight:700; line-height:0.95;
            letter-spacing:-3px;
            margin-bottom:32px;
        }
        .hero-title .line-accent {
            background:linear-gradient(90deg, var(--accent), #34d399);
            -webkit-background-clip:text; -webkit-text-fill-color:transparent;
        }

        .hero-sub {
            font-size:18px; color:var(--muted); max-width:560px;
            line-height:1.7; margin-bottom:48px;
        }

        .hero-actions {
            display:flex; align-items:center; gap:16px; flex-wrap:wrap; justify-content:center;
        }
        .btn-primary {
            padding:16px 40px; border-radius:14px;
            background:var(--accent); color:#000;
            font-family:'Space Mono', monospace; font-size:13px; font-weight:700;
            text-decoration:none; letter-spacing:0.5px;
            transition:all 0.25s var(--ease);
            display:inline-flex; align-items:center; gap:10px;
        }
        .btn-primary:hover { transform:translateY(-3px); box-shadow:0 16px 40px var(--accent-glow); }
        .btn-secondary {
            padding:16px 40px; border-radius:14px;
            border:1px solid var(--border); color:var(--muted);
            font-family:'Space Mono', monospace; font-size:13px;
            text-decoration:none; letter-spacing:0.5px;
            transition:all 0.25s var(--ease);
        }
        .btn-secondary:hover { border-color:rgba(52,211,153,0.4); color:var(--text); }

        /* Live counter */
        .hero-stat {
            margin-top:64px;
            display:flex; align-items:center; gap:48px;
            padding:24px 48px;
            background:rgba(2,26,21,0.6);
            border:1px solid var(--border);
            border-radius:20px;
            backdrop-filter:blur(20px);
        }
        .hero-stat-item { text-align:center; }
        .hero-stat-item .num {
            font-family:'Clash Display', sans-serif;
            font-size:36px; font-weight:700; color:var(--accent);
            display:block;
        }
        .hero-stat-item .label {
            font-family:'Space Mono', monospace;
            font-size:10px; color:var(--muted); text-transform:uppercase; letter-spacing:1px;
        }
        .stat-divider { width:1px; height:40px; background:var(--border); }

        /* ── SCROLL TICKER ── */
        .ticker-wrap {
            position:relative; z-index:1;
            overflow:hidden; border-top:1px solid var(--border); border-bottom:1px solid var(--border);
            padding:14px 0; background:rgba(2,26,21,0.3);
        }
        .ticker-track {
            display:flex; gap:0; white-space:nowrap;
            animation:ticker 25s linear infinite;
        }
        .ticker-item {
            font-family:'Space Mono', monospace; font-size:12px; color:var(--muted);
            padding:0 40px; text-transform:uppercase; letter-spacing:1px;
            display:flex; align-items:center; gap:16px;
        }
        .ticker-dot { width:4px; height:4px; border-radius:50%; background:var(--accent); flex-shrink:0; }
        @keyframes ticker { from{transform:translateX(0)} to{transform:translateX(-50%)} }

        /* ── FEATURES ── */
        .features {
            position:relative; z-index:1;
            padding:120px 48px;
            max-width:1200px; margin:0 auto;
        }
        .section-label {
            font-family:'Space Mono', monospace; font-size:11px; color:var(--accent);
            text-transform:uppercase; letter-spacing:3px; margin-bottom:20px;
        }
        .section-title {
            font-family:'Clash Display', sans-serif; font-size:clamp(36px,5vw,60px);
            font-weight:700; letter-spacing:-1.5px; margin-bottom:64px;
            max-width:600px; line-height:1.05;
        }
        .features-grid {
            display:grid; grid-template-columns:repeat(auto-fit, minmax(300px,1fr));
            gap:2px; border:1px solid var(--border); border-radius:20px; overflow:hidden;
        }
        .feature-card {
            padding:40px; background:rgba(2,26,21,0.4);
            transition:background 0.3s var(--ease);
            border-right:1px solid var(--border); border-bottom:1px solid var(--border);
        }
        .feature-card:hover { background:rgba(16,185,129,0.05); }
        .feature-icon {
            font-size:28px; margin-bottom:20px; display:block;
        }
        .feature-card h3 {
            font-family:'Clash Display', sans-serif; font-size:22px; margin-bottom:12px;
        }
        .feature-card p { font-size:14px; color:var(--muted); line-height:1.7; }

        /* ── HOW IT WORKS ── */
        .how-it-works {
            position:relative; z-index:1;
            padding:80px 48px 120px; max-width:1000px; margin:0 auto;
        }
        .steps { display:flex; flex-direction:column; gap:0; }
        .step {
            display:grid; grid-template-columns:80px 1fr;
            gap:32px; padding:40px 0;
            border-bottom:1px solid var(--border);
            align-items:start;
        }
        .step:last-child { border-bottom:none; }
        .step-num {
            font-family:'Clash Display', sans-serif;
            font-size:48px; font-weight:700; color:var(--accent); opacity:0.3;
            line-height:1;
        }
        .step h4 { font-family:'Clash Display', sans-serif; font-size:24px; margin-bottom:10px; }
        .step p { font-size:14px; color:var(--muted); line-height:1.7; max-width:500px; }

        /* ── FOOTER CTA ── */
        .footer-cta {
            position:relative; z-index:1;
            text-align:center; padding:100px 24px 80px;
            border-top:1px solid var(--border);
        }
        .footer-cta h2 {
            font-family:'Clash Display', sans-serif;
            font-size:clamp(40px,7vw,80px); font-weight:700;
            letter-spacing:-2px; margin-bottom:24px; line-height:1;
        }
        .footer-cta p { font-size:16px; color:var(--muted); margin-bottom:40px; }
        .footer-bottom {
            margin-top:80px; padding-top:24px; border-top:1px solid var(--border);
            font-family:'Space Mono', monospace; font-size:11px; color:var(--muted);
            display:flex; justify-content:space-between; align-items:center;
            max-width:1200px; margin:80px auto 0;
        }

        /* ── GLOW BLOB ── */
        .glow-blob {
            position:fixed; border-radius:50%; filter:blur(120px);
            pointer-events:none; z-index:0; opacity:0.15;
        }
        .blob-1 { width:600px; height:600px; background:var(--accent); top:-200px; left:-200px; }
        .blob-2 { width:400px; height:400px; background:#34d399; bottom:-100px; right:-100px; }

        /* ── MOBILE ── */
        @media (max-width: 768px) {
            nav { padding:16px 20px; }
            .nav-links { gap:16px; }
            .nav-links a:not(.nav-cta) { display:none; }
            .hero { padding:100px 20px 60px; }
            .hero-stat { flex-direction:column; gap:20px; padding:20px 32px; }
            .stat-divider { width:40px; height:1px; }
            .features, .how-it-works { padding:60px 20px; }
            .feature-card { padding:28px; }
            .step { grid-template-columns:50px 1fr; gap:16px; }
            .footer-bottom { flex-direction:column; gap:12px; text-align:center; }
        }

        /* ── ANIMATE IN ── */
        .fade-up {
            opacity:0; transform:translateY(24px);
            animation:fadeUp 0.7s var(--ease) forwards;
        }
        .fade-up:nth-child(1) { animation-delay:0.1s; }
        .fade-up:nth-child(2) { animation-delay:0.2s; }
        .fade-up:nth-child(3) { animation-delay:0.3s; }
        .fade-up:nth-child(4) { animation-delay:0.4s; }
        @keyframes fadeUp { to { opacity:1; transform:translateY(0); } }
    </style>
</head>
<body>

<div class="glow-blob blob-1"></div>
<div class="glow-blob blob-2"></div>

<!-- NAV -->
<nav>
    <div class="nav-brand">Z-NODE</div>
    <div class="nav-links">
        <a href="#features">Features</a>
        <a href="#how">How it works</a>
        <a href="app.html">Sign In</a>
        <a href="onboarding.html" class="nav-cta">Join Now →</a>
    </div>
</nav>

<!-- HERO -->
<section class="hero">
    <div class="hero-eyebrow fade-up">Nigeria's Student Identity Network</div>
    <h1 class="hero-title fade-up">
        Your Campus.<br>
        <span class="line-accent">Your Network.</span><br>
        Your Legacy.
    </h1>
    <p class="hero-sub fade-up">
        Z-Node connects Nigerian university students with their cohort, builds their digital identity, and lets their peers crown the stars of each department.
    </p>
    <div class="hero-actions fade-up">
        <a href="onboarding.html" class="btn-primary">
            <span>Join Z-Node</span>
            <span>→</span>
        </a>
        <a href="app.html" class="btn-secondary">Sign In</a>
    </div>

    <div class="hero-stat fade-up" id="heroStats">
        <div class="hero-stat-item">
            <span class="num" id="statStudents">—</span>
            <span class="label">Students</span>
        </div>
        <div class="stat-divider"></div>
        <div class="hero-stat-item">
            <span class="num" id="statUniversities">20+</span>
            <span class="label">Universities</span>
        </div>
        <div class="stat-divider"></div>
        <div class="hero-stat-item">
            <span class="num" id="statLikes">—</span>
            <span class="label">Likes Given</span>
        </div>
    </div>
</section>

<!-- TICKER -->
<div class="ticker-wrap">
    <div class="ticker-track" id="tickerTrack">
        <!-- JS fills this -->
    </div>
</div>

<!-- FEATURES -->
<section class="features" id="features">
    <p class="section-label">What Z-Node does</p>
    <h2 class="section-title">Built for Nigerian students. By design.</h2>
    <div class="features-grid">
        <div class="feature-card">
            <span class="feature-icon">🪪</span>
            <h3>Digital Identity</h3>
            <p>Your Z-Node Passport ties your university, department, and matric number into one verified digital identity — your record on the network forever.</p>
        </div>
        <div class="feature-card">
            <span class="feature-icon">🏆</span>
            <h3>Department Star</h3>
            <p>Share your profile link, collect likes from friends and family, and climb to the top of your department leaderboard. The most liked student becomes the Department Star of the year.</p>
        </div>
        <div class="feature-card">
            <span class="feature-icon">📖</span>
            <h3>E-Yearbook</h3>
            <p>Every verified student gets a profile card in the graduating cohort's Network Directory — a digital yearbook your whole class can browse forever.</p>
        </div>
        <div class="feature-card">
            <span class="feature-icon">🔗</span>
            <h3>Social Layer</h3>
            <p>Link your X, Instagram, LinkedIn and GitHub. Your Z-Node profile becomes the single link that holds your entire student identity together.</p>
        </div>
        <div class="feature-card">
            <span class="feature-icon">✅</span>
            <h3>Admin Verified</h3>
            <p>Every profile is reviewed and verified by your institution's admin team before going live — keeping the network authentic and trustworthy.</p>
        </div>
        <div class="feature-card">
            <span class="feature-icon">🚀</span>
            <h3>More Coming</h3>
            <p>Payments, student discounts, AI tools, and campus services are being built into the network. Z-Node v1 is just the beginning.</p>
        </div>
    </div>
</section>

<!-- HOW IT WORKS -->
<section class="how-it-works" id="how">
    <p class="section-label">How it works</p>
    <h2 class="section-title">From signup to star.</h2>
    <div class="steps">
        <div class="step">
            <div class="step-num">01</div>
            <div>
                <h4>Create your Z-Node account</h4>
                <p>Pick your vibe, enter your university details, upload your photo, and set your eternal statement — the one thing you want your cohort to remember you by.</p>
            </div>
        </div>
        <div class="step">
            <div class="step-num">02</div>
            <div>
                <h4>Wait for admin verification</h4>
                <p>Your institution's admin reviews and verifies your profile against real student records. Once approved, your card goes live in the Network Directory.</p>
            </div>
        </div>
        <div class="step">
            <div class="step-num">03</div>
            <div>
                <h4>Share your profile link</h4>
                <p>Copy your unique profile link and share it anywhere — WhatsApp, Instagram, X. Anyone who clicks it can like your profile. No account needed to like.</p>
            </div>
        </div>
        <div class="step">
            <div class="step-num">04</div>
            <div>
                <h4>Become the Department Star</h4>
                <p>The student with the most likes in each department is crowned the Department Star on the Z-Node leaderboard. Get your people to vote.</p>
            </div>
        </div>
    </div>
</section>

<!-- FOOTER CTA -->
<section class="footer-cta">
    <h2>Ready to join<br><span style="color:var(--accent)">the network?</span></h2>
    <p>It takes less than 5 minutes to set up your Z-Node identity.</p>
    <a href="onboarding.html" class="btn-primary" style="display:inline-flex;">
        <span>Create Your Profile</span>
        <span>→</span>
    </a>
    <div class="footer-bottom">
        <span>© 2026 Z-Node. Nigeria's Student Network.</span>
        <span style="color:var(--accent);">Built different. 🇳🇬</span>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
    // ── SUPABASE LIVE STATS ────────────────────────────────
    const SUPABASE_URL  = "https://yohndnmwvgcwadkytmix.supabase.co";
    const SUPABASE_ANON = "YOUR_SUPABASE_ANON_KEY_HERE";

    async function loadStats() {
        try {
            const { createClient } = supabase;
            const db = createClient(SUPABASE_URL, SUPABASE_ANON);

            const { count: studentCount } = await db.from('students').select('*', { count:'exact', head:true }).eq('is_verified', true);
            const { data: likesData } = await db.from('students').select('likes_count').eq('is_verified', true);
            const totalLikes = (likesData || []).reduce((sum, s) => sum + (s.likes_count || 0), 0);

            document.getElementById('statStudents').textContent    = studentCount || 0;
            document.getElementById('statLikes').textContent       = totalLikes || 0;
        } catch(e) {
            document.getElementById('statStudents').textContent = '—';
            document.getElementById('statLikes').textContent    = '—';
        }
    }
    loadStats();

    // ── TICKER ─────────────────────────────────────────────
    const tickerItems = [
        'Digital Identity', 'Department Stars', 'E-Yearbook 2026',
        'Verified Students', 'Network Directory', 'Z-Node Passport',
        'Nigeria\'s Campus Network', 'Share Your Profile', 'Get Liked',
        'UNILAG', 'ABU', 'OAU', 'UI', 'FULAFIA', 'UNIBEN', 'BUK',
    ];
    const track = document.getElementById('tickerTrack');
    // Double the items so the loop is seamless
    [...tickerItems, ...tickerItems].forEach(item => {
        const el = document.createElement('span');
        el.className = 'ticker-item';
        el.innerHTML = `<span class="ticker-dot"></span>${item}`;
        track.appendChild(el);
    });

    // ── IF LOGGED IN, SHOW "GO TO APP" instead ─────────────
    if (localStorage.getItem('znodeStudentProfile')) {
        document.querySelectorAll('a[href="onboarding.html"]').forEach(a => {
            a.href = 'app.html';
            a.textContent = 'Go to My Dashboard →';
        });
    }
</script>
</body>
</html>